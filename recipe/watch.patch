From daef99de15706e63a6711332e931c826d87d648f Mon Sep 17 00:00:00 2001
From: Jan Janssen <jan-janssen@users.noreply.github.com>
Date: Mon, 22 Jun 2026 10:12:08 +0200
Subject: [PATCH] [Fix] Fixes based on testing in pyiron_base (#298)

---
 src/pyfileindex/pyfileindex.py | 2 +-
 src/pyfileindex/watcher.py     | 4 ++++
 2 files changed, 5 insertions(+), 1 deletion(-)

diff --git a/src/pyfileindex/pyfileindex.py b/src/pyfileindex/pyfileindex.py
index 54144c5..2d07434 100644
--- a/src/pyfileindex/pyfileindex.py
+++ b/src/pyfileindex/pyfileindex.py
@@ -40,7 +40,7 @@ def __init__(
         if watch:
             self._watcher = FileSystemWatcher(path=self._path)
             self._watcher.start()
-        if df is None:
+        if df is None or watch:
             self._df = self._create_df_from_lst(
                 [self._get_lst_entry_from_path(entry=self._path)]
                 + list(self._scandir(path=self._path, df=None, recursive=True))
diff --git a/src/pyfileindex/watcher.py b/src/pyfileindex/watcher.py
index 55e64e7..5ce9b72 100644
--- a/src/pyfileindex/watcher.py
+++ b/src/pyfileindex/watcher.py
@@ -1,3 +1,4 @@
+import atexit
 import threading
 from collections.abc import Generator
 from typing import Optional
@@ -53,12 +64,14 @@ def start(self) -> None:
             next(self._generator)
         self._thread = threading.Thread(target=self._worker, daemon=True)
         self._thread.start()
+        atexit.register(self.stop)
 
     def stop(self) -> None:
         """
         Stop the background file system watcher. Safe to call even if no
         watcher is running.
         """
+        atexit.unregister(self.stop)
         if self._stop_event is not None:
             self._stop_event.set()
         if self._thread is not None:
@@ -86,6 +93,7 @@ def drain_pending_changes(self, timeout: float = 0.0) -> set:
             set: set of (watchfiles.Change, path) tuples
         """
         if timeout > 0:
+            self._changes_available.clear()
             self._changes_available.wait(timeout)
         with self._lock:
             changes = self._pending_changes
